# ObjectOracle Environment Variables
# Copy this to .env and fill in your values

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=changeme-super-secret-key

# Model paths (auto-downloaded if not present)
YOLO_MODEL_PATH=models/yolov8n.pt
YOLO_CUSTOM_PATH=models/yolov8_custom.pt
CLIP_MODEL=ViT-B/32
SAM_CHECKPOINT=models/sam_vit_b.pth

# Inference settings
CONFIDENCE_THRESHOLD=0.40
NMS_IOU_THRESHOLD=0.45
MAX_DETECTIONS=100
DEVICE=cpu           # cpu | cuda | mps

# Redis (for async batch jobs)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
